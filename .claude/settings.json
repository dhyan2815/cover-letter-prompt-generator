{
  "hooks": {
    "on_exit": "session-memory-updater"
  },
  "permissions": {
    "allow": [
      "Read(**)",
      "Write(src/**)",
      "Write(test/**)",
      "Write(.claude/**)",
      "Bash(make:*)",
      "Bash(npm run:*)",
      "Bash(npm test *)",
      "Bash(npm run build *)"
    ],
    "deny": [
      "Bash(rm -rf *)"
    ]
  }
}